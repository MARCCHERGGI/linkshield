{
  "manifest_version": 3,
  "name": "LinkShield",
  "version": "1.0.0",
  "description": "Scans every link before you click it. Phishing, malware, scams — blocked before they touch you.",
  "permissions": [
    "activeTab",
    "storage",
    "webNavigation",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkShield"
  },
  "icons": {
    "16": "icons/shield-16.png",
    "48": "icons/shield-48.png",
    "128": "icons/shield-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["check.html"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
